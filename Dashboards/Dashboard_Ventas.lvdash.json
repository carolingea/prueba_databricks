{
  "datasets": [
    {
      "name": "260cd3d1",
      "displayName": "Monedas",
      "queryLines": [
        "SELECT '$US', 'Dolares' as moneda\r\n",
        "UNION \r\n",
        "ALL SELECT '$', 'Pesos' as moneda\r\n"
      ]
    },
    {
      "name": "fe30df40",
      "displayName": "Vista_ventas",
      "queryLines": [
        "select \r\n",
        "    p.Name as Product, p.Category, p.Brand, p.Price, p.Currency, p.Stock, p.EAN, p.Color, p.Size, p.Availability, \r\n",
        "    c.`First Name`, c.`Last Name`, c.Company, c.City, c.Country, c.Email, c.`Phone 1`, c.`Phone 2`,\r\n",
        "    v.Price as PriceSale, v.Quantity as QuantitySale, v.Total, v.Id\r\n",
        "FROM ventas v\r\n",
        "INNER JOIN workspace.default.products p on p.Index = v.productid\r\n",
        "INNER JOIN workspace.default.customers c on c.Index = v.customerid"
      ]
    },
    {
